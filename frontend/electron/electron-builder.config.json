{
  "appId": "com.anurag.ltm",
  "productName": "Thinking Space",
  "directories": {
    "buildResources": "resources"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*",
    "node_modules/node-pty/**/*"
  ],
  "asarUnpack": [
    "**/node_modules/node-pty/**"
  ],
  "extraResources": [
    {
      "from": "src/cli",
      "to": "cli",
      "filter": ["**/*"]
    },
    {
      "from": "../",
      "to": "source",
      "filter": [
        "package.json",
        "package-lock.json",
        "vite.config.ts",
        "tsconfig.json",
        "tsconfig.node.json",
        "index.html",
        "src/**",
        "public/**",
        "scripts/**",
        "electron/package.json",
        "electron/package-lock.json",
        "electron/tsconfig.json",
        "electron/capacitor.config.ts",
        "electron/src/**",
        "electron/assets/**",
        "electron/resources/**",
        "electron/electron-builder.config.json",
        "!**/node_modules/**",
        "!electron/dist/**",
        "!electron/build/**",
        "!electron/app/**"
      ]
    }
  ],
  "publish": {
    "provider": "github"
  },
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "win": {
    "target": "nsis",
    "artifactName": "${productName} Setup ${version}-${arch}.${ext}",
    "icon": "assets/appIcon.ico"
  },
  "mac": {
    "category": "public.app-category.productivity",
    "target": "dmg",
    "icon": "assets/appIcon.png"
  },
  "linux": {
    "target": "AppImage",
    "icon": "assets/appIcon.png",
    "category": "Office"
  }
}
