{
  "appId": "com.anurag.ltm",
  "productName": "Thinking Space",
  "directories": {
    "buildResources": "resources"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "extraResources": [
    {
      "from": "src/cli",
      "to": "cli",
      "filter": ["**/*"]
    }
  ],
  "publish": {
    "provider": "github"
  },
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "win": {
    "target": "nsis",
    "artifactName": "${productName} Setup ${version}-${arch}.${ext}",
    "icon": "assets/appIcon.ico"
  },
  "mac": {
    "category": "public.app-category.productivity",
    "target": "dmg",
    "icon": "assets/appIcon.png"
  },
  "linux": {
    "target": "AppImage",
    "icon": "assets/appIcon.png",
    "category": "Office"
  }
}
