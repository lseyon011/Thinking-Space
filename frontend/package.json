{
  "name": "thinking-space-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync:excalidraw-fonts": "node scripts/syncExcalidrawFonts.mjs",
    "dev": "npm run sync:excalidraw-fonts && vite",
    "build": "npm run sync:excalidraw-fonts && tsc && vite build",
    "build:web": "npm run sync:excalidraw-fonts && tsc && vite build",
    "build:electron": "npm run sync:excalidraw-fonts && tsc && BUILD_TARGET=electron vite build",
    "build:ios": "npm run sync:excalidraw-fonts && tsc && BUILD_TARGET=capacitor vite build && npx cap sync ios",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:sync": "npm run build:electron && npx cap sync @capacitor-community/electron",
    "electron:dev": "npm run electron:sync && cd electron && npm run electron:start",
    "package:mac": "npm run electron:sync && cd electron && npm run electron:make:mac",
    "package:win": "npm run electron:sync && cd electron && npm run electron:make:win",
    "package:linux": "npm run electron:sync && cd electron && npm run electron:make:linux",
    "package:ios": "npm run build:ios && npx cap open ios",
    "agent:capabilities": "vite-node scripts/agent/capabilityRunner.ts",
    "agent:workspace:bootstrap": "vite-node scripts/agent/bootstrapAgentWorkspace.ts",
    "agent:workspace:restructure": "vite-node scripts/agent/restructureAgentWorkspace.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/filesystem": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.14",
    "@excalidraw/excalidraw": "^0.18.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-toolbar": "^1.1.11",
    "@uiw/react-codemirror": "^4.25.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dexie": "^4.3.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.468.0",
    "markdown-table": "^3.0.4",
    "openai": "^6.21.0",
    "pdfjs-dist": "^5.4.296",
    "react": "^18.3.1",
    "react-datasheet-grid": "^4.11.5",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@capacitor-community/electron": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
