{
  "name": "ltm-pilot-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:electron": "tsc && BUILD_TARGET=electron vite build",
    "electron:sync": "npm run build:electron && npx cap sync @capacitor-community/electron",
    "electron:dev": "npm run electron:sync && cd electron && npm run electron:start",
    "agent:capabilities": "vite-node scripts/agent/capabilityRunner.ts",
    "agent:workspace:bootstrap": "vite-node scripts/agent/bootstrapAgentWorkspace.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/filesystem": "^8.1.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dexie": "^4.3.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.468.0",
    "openai": "^6.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@capacitor-community/electron": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
