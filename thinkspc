#!/usr/bin/env bash
# thinkspc — thin wrapper for the Thinking Space capability runner
# Usage:
#   ./thinkspc list
#   ./thinkspc organizer.nodes.list_roots --typeFilter program
#   ./thinkspc organizer.context --url "http://localhost:5173/thinking-space/thinking-organizer?tab=backlog&projectRoot=operations%2Fsfw"
#   ./thinkspc invoke < payload.json

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
FRONTEND_DIR="$REPO_ROOT/frontend"

if [ -f "$REPO_ROOT/.env" ]; then
  set -a
  # shellcheck disable=SC1091
  source "$REPO_ROOT/.env"
  set +a
fi

# Compatibility bridge:
# - new name: THINKSPC_VAULT_ROOT
# - legacy name: LTM_VAULT_ROOT
if [ -z "${THINKSPC_VAULT_ROOT:-}" ] && [ -n "${LTM_VAULT_ROOT:-}" ]; then
  THINKSPC_VAULT_ROOT="$LTM_VAULT_ROOT"
fi
if [ -z "${LTM_VAULT_ROOT:-}" ] && [ -n "${THINKSPC_VAULT_ROOT:-}" ]; then
  LTM_VAULT_ROOT="$THINKSPC_VAULT_ROOT"
fi

export THINKSPC_VAULT_ROOT="${THINKSPC_VAULT_ROOT:-${LTM_VAULT_ROOT:-}}"
export LTM_VAULT_ROOT="${LTM_VAULT_ROOT:-}"
export LTM_AGENT_CAPABILITIES_ENABLED=1
export LTM_CAPABILITY_RUNNER_CLI=1

if [ -z "${LTM_VAULT_ROOT:-}" ]; then
  echo "Error: THINKSPC_VAULT_ROOT/LTM_VAULT_ROOT is not set." >&2
  echo "Set it in $REPO_ROOT/.env or export it before running." >&2
  exit 1
fi

cd "$FRONTEND_DIR"
exec npx vite-node scripts/agent/capabilityRunner.ts "$@"
