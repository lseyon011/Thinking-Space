#!/usr/bin/env bash
# thinkspc — Thinking Space CLI dispatcher.
#
# Single source of truth: always runs the bundled CLI via Electron-as-Node.
# No vite-node, no node_modules, no separate dev runtime.
#
# Bundle location precedence:
#   1. Repo bundle at frontend/electron/resources/cli/thinkspc-runner.mjs
#      (present in dev after `node frontend/scripts/bundle-cli.mjs` or any
#      electron build). Lets you iterate by re-running the bundle.
#   2. Installed bundle at ~/.thinking-space/bin/thinkspc-runner.mjs
#      (written by the Electron app on launch — provisionCliBlock).
#
# Either path uses the SAME runtime: ELECTRON_RUN_AS_NODE=1 against the
# packaged Thinking Space.app binary.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
ELECTRON_BIN="/Applications/Thinking Space.app/Contents/MacOS/Thinking Space"
REPO_BUNDLE="$REPO_ROOT/frontend/electron/resources/cli/thinkspc-runner.mjs"
INSTALLED_BUNDLE="$HOME/.thinking-space/bin/thinkspc-runner.mjs"

# Pick the bundle: prefer repo (dev iteration), fall back to installed (prod).
if [ -f "$REPO_BUNDLE" ]; then
  BUNDLE="$REPO_BUNDLE"
elif [ -f "$INSTALLED_BUNDLE" ]; then
  BUNDLE="$INSTALLED_BUNDLE"
else
  cat >&2 <<EOF
Error: thinkspc bundle not found.

  Tried:
    $REPO_BUNDLE   (run: node frontend/scripts/bundle-cli.mjs)
    $INSTALLED_BUNDLE (provisioned when you launch Thinking Space.app)

  Either build the bundle for local dev, or install + launch the app once.
EOF
  exit 1
fi

if [ ! -x "$ELECTRON_BIN" ]; then
  echo "Error: Thinking Space.app not installed at $ELECTRON_BIN" >&2
  echo "Build with ./build.sh mac and install the DMG to /Applications/." >&2
  exit 1
fi

# Vault root: env wins; else read from config.json (written by the app on
# launch); else source repo .env if present; else the runner itself will
# error with a clear message.
if [ -z "${THINKSPC_VAULT_ROOT:-}${LTM_VAULT_ROOT:-}" ] && [ -f "$REPO_ROOT/.env" ]; then
  set -a
  # shellcheck disable=SC1091
  source "$REPO_ROOT/.env"
  set +a
fi

: "${LTM_OUTPUT_FORMAT:=text}"
: "${LTM_OUTPUT_BRIEF:=1}"
export LTM_OUTPUT_FORMAT LTM_OUTPUT_BRIEF
export LTM_AGENT_CAPABILITIES_ENABLED=1
export LTM_CAPABILITY_RUNNER_CLI=1
export THINKSPC_CALLER_CWD="$PWD"
[ -n "${THINKSPC_VAULT_ROOT:-}" ] && export THINKSPC_VAULT_ROOT
[ -n "${LTM_VAULT_ROOT:-}" ] && export LTM_VAULT_ROOT

exec env ELECTRON_RUN_AS_NODE=1 "$ELECTRON_BIN" "$BUNDLE" "$@"
